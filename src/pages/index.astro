---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="https://www.maxqanalytics.io" class="flex items-center">
        <img src="/maxq-logo.png" alt="Maxq Analytics" class="h-9 w-9 rounded-md object-cover" />
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-slate-600 font-medium">
        <a href="#product-items" class="hover:text-brand-600 transition-colors">Product</a>
        <a href="#frameworks" class="hover:text-brand-600 transition-colors">Frameworks</a>
        <a href="#stack" class="hover:text-brand-600 transition-colors">Tech Stack</a>
        <a href="#pricing" class="hover:text-brand-600 transition-colors">Pricing</a>
        <a href="https://calendly.com/philip-boontje" target="_blank" rel="noopener" class="bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors">
          Contact us
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-24 px-6 bg-gradient-to-br from-brand-950 via-brand-900 to-brand-700 text-white">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
        Semantic<br /><span class="text-brand-300">Nexus</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        Our flagship data architecture that gives your entire organisation a single source of truth — from raw data to boardroom KPIs.
      </p>
    </div>
  </section>

  <!-- Client Logo Carousel -->
  <section class="py-14 bg-white border-b border-slate-100 overflow-hidden">
    <p class="text-center text-sm font-medium text-slate-400 uppercase tracking-widest mb-8">Trusted by</p>
    <div class="relative">
      <div class="flex gap-16 items-center animate-marquee whitespace-nowrap">
        {[
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6dc816b4f62d5c56f90_Delta-Safety-Training.png', alt: 'Delta Safety Training', href: 'https://www.deltasafetytraining.nl' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6d49b1ad2fcefbd8d2d_logo-clubcollect%20(1).png', alt: 'Club Collect', href: 'https://www.clubcollect.com', h: 'h-6' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/648aec0b84ca07f77700a234_bootman_logo.png', alt: 'Bootman', href: 'https://www.bootman.nl', h: 'h-6' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/649150688a5331c19bc40445_ciphix_logo.png', alt: 'Ciphix', href: 'https://www.ciphix.com', h: 'h-6' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/64e9b09b165f6871809ceb5e_Freeday-logo.png', alt: 'Freeday', href: 'https://www.freeday.ai' },
          { src: '/cjob-logo.jpeg', alt: 'C-Job Naval Architects', href: 'https://c-job.com' },
          { src: '/rebelsai-logo.jpeg', alt: 'RebelsAI', href: 'https://www.rebelsai.nl' },
          { src: '/twelve-logo.svg', alt: 'Twelve', href: 'https://www.twelve.eu', h: 'h-6' },
          /* duplicate set for seamless loop */
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6dc816b4f62d5c56f90_Delta-Safety-Training.png', alt: 'Delta Safety Training', href: 'https://www.deltasafetytraining.nl' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6d49b1ad2fcefbd8d2d_logo-clubcollect%20(1).png', alt: 'Club Collect', href: 'https://www.clubcollect.com', h: 'h-6' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/648aec0b84ca07f77700a234_bootman_logo.png', alt: 'Bootman', href: 'https://www.bootman.nl', h: 'h-6' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/649150688a5331c19bc40445_ciphix_logo.png', alt: 'Ciphix', href: 'https://www.ciphix.com', h: 'h-6' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/64e9b09b165f6871809ceb5e_Freeday-logo.png', alt: 'Freeday', href: 'https://www.freeday.ai' },
          { src: '/cjob-logo.jpeg', alt: 'C-Job Naval Architects', href: 'https://c-job.com' },
          { src: '/rebelsai-logo.jpeg', alt: 'RebelsAI', href: 'https://www.rebelsai.nl' },
          { src: '/twelve-logo.svg', alt: 'Twelve', href: 'https://www.twelve.eu', h: 'h-6' },
        ].map(logo => (
          <a href={logo.href} target="_blank" rel="noopener" class="inline-flex items-center shrink-0">
            <img src={logo.src} alt={logo.alt} class={`${logo.h ?? 'h-10'} w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300`} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      animation: marquee 30s linear infinite;
      width: max-content;
    }
    .animate-marquee:hover {
      animation-play-state: paused;
    }
  </style>

  <!-- Stats -->
  <section class="py-20 px-6 bg-brand-950 text-white">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-4 text-center">
        {[
          { value: '8', label: 'Data engineers' },
          { value: '9', label: 'Active clients' },
          { value: '460+', label: 'FTE across clients' },
          { value: '€63M+', label: 'Combined annual revenue' },
          { value: '25k+', label: 'Analytics API requests / day' },
        ].map(stat => (
          <div class="flex flex-col gap-2">
            <span class="text-4xl md:text-5xl font-extrabold text-white tracking-tight">{stat.value}</span>
            <span class="text-sm text-white/50 leading-snug">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Business Impact -->
  <section class="py-24 px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">What it brings to your business</h2>
        <p class="text-xl text-slate-500 max-w-2xl mx-auto">The Semantic Nexus is designed to remove ambiguity, reduce overhead, and give every team a reliable foundation to make decisions from.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl p-8 border border-slate-200">
          <div class="text-3xl font-extrabold text-brand-600 mb-3">One truth</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Aligned across every team</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Leadership, finance, and operations all work from the same semantic layer. No more conflicting spreadsheets or disputed numbers — every metric is defined once and used everywhere.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-200">
          <div class="text-3xl font-extrabold text-brand-600 mb-3">Less overhead</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Fewer ad-hoc requests</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Finance and planning managers run their own calculations directly against the semantic model. Your data team spends less time answering one-off questions and more time building what matters.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-200">
          <div class="text-3xl font-extrabold text-brand-600 mb-3">Full trust</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Data you can rely on</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Automated data entry tests and pipeline freshness monitoring catch issues before they reach decision-makers. Your reports are only as good as the data behind them — so we make sure it stays clean.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-200">
          <div class="text-3xl font-extrabold text-brand-600 mb-3">Stakeholder ready</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">KPIs straight to the boardroom</h3>
          <p class="text-slate-600 text-sm leading-relaxed">After a successful deployment, monthly company KPIs can be shared directly with shareholders and stakeholders through the metrics exchange — no manual exports, no preparation overhead.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-200">
          <div class="text-3xl font-extrabold text-brand-600 mb-3">Full ownership</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Your data, your infrastructure</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Every repository is version-controlled and owned by the client. No vendor lock-in, no black-box dependencies. You can switch tools or engineers without losing your architecture.</p>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-slate-200">
          <div class="text-3xl font-extrabold text-brand-600 mb-3">AI ready</div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Natural language on your data</h3>
          <p class="text-slate-600 text-sm leading-relaxed">With the MCP Server, your semantic layer becomes accessible to AI agents. Ask questions in plain language and get answers grounded in your actual data model — not hallucinations.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Product Items -->
  <section id="product-items" class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Product items</h2>
        <p class="text-xl text-slate-500 max-w-2xl mx-auto">Five components that together give your organisation complete visibility into its data — from raw sources to AI-powered querying.</p>
      </div>

      <!-- Top row: 3 cards -->
      <div class="grid md:grid-cols-3 gap-6 mb-6">

        <!-- Data Model Explorer -->
        <div class="bg-slate-50 rounded-2xl p-7 flex flex-col">
          <div class="w-11 h-11 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6M9 8h6M9 16h4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Data Model Explorer</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">A unified, navigable interface that maps your entire data architecture. Source tables are shown post-transformation with aggregations for fast analysis. Each critical metric gets its own dedicated page with a scorecard, numerator/denominator breakdown, and business context provided by the client.</p>
          <a href="https://docs.maxqanalytics.io/Products/Semantic+Nexus#Data%20Model%20Explorer" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors">View in docs →</a>
        </div>

        <!-- Data Entry Tests -->
        <div class="bg-slate-50 rounded-2xl p-7 flex flex-col">
          <div class="w-11 h-11 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Data Entry Tests</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">Automated, client-specific tests that continuously validate data entries and business workflows. Each test is assigned an owner, a deeplink for direct resolution at the source, a context description, and a unique test ID — keeping data quality accountable and easy to communicate across teams.</p>
          <a href="https://docs.maxqanalytics.io/Products/Semantic+Nexus#Data+Entry+Tests" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors">View in docs →</a>
        </div>

        <!-- Pipeline Freshness -->
        <div class="bg-slate-50 rounded-2xl p-7 flex flex-col">
          <div class="w-11 h-11 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Pipeline Freshness</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">A live flowchart of your full data pipeline from extraction through transformation to consumption. Every stakeholder can see how data moves across your architecture — which systems are involved, what the current status is, and where bottlenecks occur. Invaluable when planning refactors or expansions.</p>
          <a href="https://docs.maxqanalytics.io/Products/Semantic+Nexus#Data+Freshness" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors">View in docs →</a>
        </div>

      </div>

      <!-- Bottom row: 2 cards centred -->
      <div class="grid md:grid-cols-2 gap-6 md:max-w-3xl md:mx-auto">

        <!-- Domain Reports -->
        <div class="bg-slate-50 rounded-2xl p-7 flex flex-col">
          <div class="w-11 h-11 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Domain Reports</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">Three purpose-built reporting domains aligned to how companies are structured: <strong>Commerce Atlas</strong> (go-to-market, unit economics), <strong>Finance Atlas</strong> (margins, financial operations), and <strong>Operations Atlas</strong> (utilisation, capacity). Each delivers periodic dashboards and trend analysis tailored to the domain's owners and targets.</p>
          <a href="https://docs.maxqanalytics.io/Products/Semantic+Nexus#Domain+Reports" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors">View in docs →</a>
        </div>

        <!-- MCP Server -->
        <div class="bg-slate-50 rounded-2xl p-7 flex flex-col">
          <div class="w-11 h-11 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">MCP Server</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-4">A Model Context Protocol server that connects your semantic layer directly to AI agents and large language models. Query your live data model in natural language through Claude and other AI systems — bridging structured analytics with conversational intelligence without leaving your existing data infrastructure.</p>
          <a href="https://docs.maxqanalytics.io/Products/Semantic+Nexus" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors">View in docs →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Frameworks -->
  <section id="frameworks" class="py-24 px-6 bg-brand-950 text-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Three core frameworks</h2>
        <p class="text-xl text-white/60 max-w-2xl mx-auto">The Semantic Nexus is underpinned by three frameworks that cover architecture, performance tracking, and security.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 flex flex-col">
          <div class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-3">SDA</div>
          <h3 class="text-xl font-bold mb-3">Standardised Data Architecture</h3>
          <p class="text-white/60 leading-relaxed text-sm mb-5">Best practices for building a data pipeline and data model that is robust, flexible, and low cost — refined over years of real client work.</p>
          <a href="https://docs.maxqanalytics.io/Design/Frameworks#Standardised%20Data%20Architecture" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-300 hover:text-white transition-colors">View in docs →</a>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 flex flex-col">
          <div class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-3">IPF</div>
          <h3 class="text-xl font-bold mb-3">Integrated Performance Framework</h3>
          <p class="text-white/60 leading-relaxed text-sm mb-5">A systematised way of presenting the data model that strikes the right balance between simplicity and depth for all stakeholders.</p>
          <a href="https://docs.maxqanalytics.io/Design/Frameworks#Integrated%20Performance%20Framework" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-300 hover:text-white transition-colors">View in docs →</a>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 flex flex-col">
          <div class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-3">MSP</div>
          <h3 class="text-xl font-bold mb-3">Modular Security Protocol</h3>
          <p class="text-white/60 leading-relaxed text-sm mb-5">A structured set of security checks designed for client-side and open-core architectures, where the security environment is inherently more complex.</p>
          <a href="https://docs.maxqanalytics.io/Design/Frameworks#Modular%20Security%20Protocol" target="_blank" rel="noopener" class="mt-auto text-xs font-semibold text-brand-300 hover:text-white transition-colors">View in docs →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section id="stack" class="py-24 px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Built on best-in-class tooling</h2>
        <p class="text-xl text-slate-500 max-w-2xl mx-auto">We work with the leading modern data stack tools, keeping clients fully sovereign over their own infrastructure.</p>
      </div>

      <!-- Pipeline stages -->
      <div class="flex flex-col md:flex-row items-stretch gap-0 md:min-h-[220px]">

        {[
          {
            stage: 'Extraction',
            color: 'bg-violet-50 border-violet-200',
            labelColor: 'text-violet-600',
            tools: [
              { src: '/logos/hevo.png', alt: 'Hevo Data', tip: 'No-code pipeline platform for extracting and syncing data from 150+ sources into your warehouse.' },
              { src: '/logos/airbyte.svg', alt: 'Airbyte', tip: 'Open-source data integration platform for syncing data from APIs, databases and files.' },
            ]
          },
          {
            stage: 'Warehouse',
            color: 'bg-blue-50 border-blue-200',
            labelColor: 'text-blue-600',
            tools: [
              { src: '/logos/bigquery.png', alt: 'BigQuery', tip: "Google's serverless, scalable cloud data warehouse built for fast SQL analytics at any scale." },
              { src: '/logos/snowflake.png', alt: 'Snowflake', tip: 'Cloud data platform with separated storage and compute, enabling flexible and cost-efficient scaling.' },
              { src: '/logos/clickhouse.png', alt: 'ClickHouse', tip: 'High-performance columnar database optimised for real-time analytics on very large datasets.' },
            ]
          },
          {
            stage: 'Transformation & Semantics',
            color: 'bg-emerald-50 border-emerald-200',
            labelColor: 'text-emerald-600',
            tools: [
              { src: '/logos/dbt.png', alt: 'dbt', tip: 'SQL-based transformation tool that lets analytics engineers build, test and document data models in version control.' },
              { src: '/logos/cube.png', alt: 'Cube', tip: 'Semantic layer that defines business metrics centrally and exposes them consistently via API to any downstream tool.' },
            ]
          },
          {
            stage: 'Data Consumption',
            color: 'bg-orange-50 border-orange-200',
            labelColor: 'text-orange-600',
            tools: [
              { src: '/logos/data-studio.png', alt: 'Data Studio', cls: 'h-6 w-auto object-contain max-w-[140px]', tip: "Google's free BI tool for building interactive, shareable dashboards connected directly to your data sources." },
              { src: '/logos/powerbi.png', alt: 'Power BI', cls: 'h-8 w-auto object-contain max-w-[120px]', tip: "Microsoft's business intelligence platform for creating rich reports and dashboards across your organisation." },
              { src: '/logos/claude.png', alt: 'Claude', cls: 'h-12 w-auto object-contain max-w-[160px]', tip: "Anthropic's AI assistant — connected to your semantic layer via MCP Server for natural language data querying." },
            ]
          },
        ].map((group, i) => (
          <div class="flex md:flex-row items-stretch flex-1">
            <div class={`flex-1 h-full border ${group.color} rounded-2xl p-8 flex flex-col`}>
              <span class={`text-xs font-bold uppercase tracking-widest ${group.labelColor}`}>{group.stage}</span>
              <div class="flex-1 flex flex-row md:flex-col gap-4 items-center justify-center mt-4">
                {group.tools.map(tool => (
                  <div class="relative group/tip bg-white/70 rounded-xl px-4 h-14 flex items-center justify-center shadow-sm cursor-default">
                    <img src={tool.src} alt={tool.alt} class={tool.cls ?? 'h-8 w-auto object-contain max-w-[120px]'} />
                    <div class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-52 bg-slate-900 text-white text-xs rounded-lg px-3 py-2 leading-relaxed opacity-0 group-hover/tip:opacity-100 transition-opacity duration-200 z-10 text-center shadow-lg">
                      {tool.tip}
                      <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-slate-900"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            {i < 3 && (
              <div class="hidden md:flex items-center px-2 text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">

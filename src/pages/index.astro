---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="https://www.maxqanalytics.io" class="flex items-center">
        <img src="/maxq-logo.png" alt="Maxq Analytics" class="h-9 w-9 rounded-md object-cover" />
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-slate-600 font-medium">
        <a href="#product" class="hover:text-brand-600 transition-colors">Product</a>
        <a href="#frameworks" class="hover:text-brand-600 transition-colors">Frameworks</a>
        <a href="#stack" class="hover:text-brand-600 transition-colors">Tech Stack</a>
        <a href="#pricing" class="hover:text-brand-600 transition-colors">Pricing</a>
        <a href="https://calendly.com/philip-boontje" target="_blank" rel="noopener" class="bg-brand-600 text-white px-4 py-2 rounded-lg hover:bg-brand-700 transition-colors">
          Contact us
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-24 px-6 bg-gradient-to-br from-brand-950 via-brand-900 to-brand-700 text-white">
    <div class="max-w-5xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-sm px-4 py-1.5 rounded-full mb-8">
        Flagship framework by Maxq Analytics
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
        Semantic<br /><span class="text-brand-300">Nexus</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        A standardised data architecture that gives your entire organisation a single source of truth — from raw data to boardroom KPIs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://calendly.com/philip-boontje" target="_blank" rel="noopener" class="bg-white text-brand-800 font-semibold px-8 py-4 rounded-xl hover:bg-brand-50 transition-colors text-lg">
          Get in touch
        </a>
        <a href="https://lookerstudio.google.com/u/0/reporting/86bd9839-3788-4b62-a1d9-4ce312bbff3e/page/p_etg6w1911c" target="_blank" rel="noopener" class="border border-white/30 text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition-colors text-lg">
          View live demo
        </a>
      </div>
    </div>
  </section>

  <!-- Client Logo Carousel -->
  <section class="py-14 bg-white border-b border-slate-100 overflow-hidden">
    <p class="text-center text-sm font-medium text-slate-400 uppercase tracking-widest mb-8">Trusted by</p>
    <div class="relative">
      <div class="flex gap-16 items-center animate-marquee whitespace-nowrap">
        {[
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6dc816b4f62d5c56f90_Delta-Safety-Training.png', alt: 'Delta Safety Training', href: 'https://www.deltasafetytraining.nl' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6d49b1ad2fcefbd8d2d_logo-clubcollect%20(1).png', alt: 'Club Collect', href: 'https://www.clubcollect.com' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/648aec0b84ca07f77700a234_bootman_logo.png', alt: 'Bootman', href: 'https://www.bootman.nl' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/649150688a5331c19bc40445_ciphix_logo.png', alt: 'Ciphix', href: 'https://www.ciphix.com' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/64e9b09b165f6871809ceb5e_Freeday-logo.png', alt: 'Freeday', href: 'https://www.freeday.ai' },
          { src: '/cjob-logo.jpeg', alt: 'C-Job Naval Architects', href: 'https://c-job.com' },
          { src: '/rebelsai-logo.jpeg', alt: 'RebelsAI', href: 'https://www.rebelsai.nl' },
          { src: '/twelve-logo.svg', alt: 'Twelve', href: 'https://www.twelve.eu' },
          /* duplicate set for seamless loop */
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6dc816b4f62d5c56f90_Delta-Safety-Training.png', alt: 'Delta Safety Training', href: 'https://www.deltasafetytraining.nl' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/6242c6d49b1ad2fcefbd8d2d_logo-clubcollect%20(1).png', alt: 'Club Collect', href: 'https://www.clubcollect.com' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/648aec0b84ca07f77700a234_bootman_logo.png', alt: 'Bootman', href: 'https://www.bootman.nl' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/649150688a5331c19bc40445_ciphix_logo.png', alt: 'Ciphix', href: 'https://www.ciphix.com' },
          { src: 'https://cdn.prod.website-files.com/5fe86bb8d7bed24c79daf68d/64e9b09b165f6871809ceb5e_Freeday-logo.png', alt: 'Freeday', href: 'https://www.freeday.ai' },
          { src: '/cjob-logo.jpeg', alt: 'C-Job Naval Architects', href: 'https://c-job.com' },
          { src: '/rebelsai-logo.jpeg', alt: 'RebelsAI', href: 'https://www.rebelsai.nl' },
          { src: '/twelve-logo.svg', alt: 'Twelve', href: 'https://www.twelve.eu' },
        ].map(logo => (
          <a href={logo.href} target="_blank" rel="noopener" class="inline-flex items-center shrink-0">
            <img src={logo.src} alt={logo.alt} class="h-10 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      animation: marquee 30s linear infinite;
      width: max-content;
    }
    .animate-marquee:hover {
      animation-play-state: paused;
    }
  </style>

  <!-- Stats -->
  <section class="py-20 px-6 bg-brand-950 text-white">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-4 text-center">
        {[
          { value: '9', label: 'Active clients' },
          { value: '€63M+', label: 'Combined annual revenue' },
          { value: '460+', label: 'FTE across clients' },
          { value: '25k+', label: 'Analytics API requests / day' },
          { value: '8', label: 'Data engineers' },
        ].map(stat => (
          <div class="flex flex-col gap-2">
            <span class="text-4xl md:text-5xl font-extrabold text-white tracking-tight">{stat.value}</span>
            <span class="text-sm text-white/50 leading-snug">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What is Semantic Nexus -->
  <section id="product" class="py-24 px-6 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-3xl">
        <h2 class="text-4xl font-bold text-slate-900 mb-6">One architecture. Full clarity.</h2>
        <p class="text-xl text-slate-600 leading-relaxed mb-6">
          The Semantic Nexus is our standard setup for clients — a data architecture grounded in years of client feedback and best practices. It connects your data sources into a single semantic layer that leadership, finance, and operations teams can all rely on.
        </p>
        <p class="text-xl text-slate-600 leading-relaxed">
          Company leadership uses it for Internal Analytics. Finance and planning teams run ad-hoc calculations against it. After a successful deployment, monthly KPIs can be shared directly with shareholders through the metrics exchange.
        </p>
      </div>
    </div>
  </section>

  <!-- Product Components -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Product components</h2>
        <p class="text-xl text-slate-500 max-w-2xl mx-auto">Everything you need to understand, monitor, and communicate your data architecture.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Data Model Explorer -->
        <div class="bg-slate-50 rounded-2xl p-8">
          <div class="w-12 h-12 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6M9 8h6M9 16h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Data Model Explorer</h3>
          <p class="text-slate-600 mb-4 leading-relaxed">A structured view of all your data — sources, metrics, data quality and pipeline health — in a single navigable interface.</p>
          <ul class="space-y-2 text-sm text-slate-600">
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Sources</strong> — multi-source tables with aggregations and event distributions</span></li>
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Metrics</strong> — dedicated pages per KPI with scorecards, numerator/denominator, and business context</span></li>
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Data Entry Tests</strong> — client-specific automated tests with owners and deeplinks</span></li>
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Data Freshness</strong> — pipeline flowchart from extraction through to consumption</span></li>
          </ul>
        </div>

        <!-- Domain Reports -->
        <div class="bg-slate-50 rounded-2xl p-8">
          <div class="w-12 h-12 bg-brand-100 text-brand-700 rounded-xl flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Domain Reports — Atlas</h3>
          <p class="text-slate-600 mb-4 leading-relaxed">Three purpose-built report domains aligned to how your business is structured — each with periodic dashboards and trend analysis.</p>
          <ul class="space-y-2 text-sm text-slate-600">
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Commerce Atlas</strong> — go-to-market performance, unit economics, and vertical breakdowns</span></li>
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Finance Atlas</strong> — financial operations, margins, and periodic performance</span></li>
            <li class="flex gap-2"><span class="text-brand-500 font-bold mt-0.5">—</span><span><strong>Operations Atlas</strong> — business operations metrics, utilisation, and capacity</span></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Frameworks -->
  <section id="frameworks" class="py-24 px-6 bg-brand-950 text-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Three core frameworks</h2>
        <p class="text-xl text-white/60 max-w-2xl mx-auto">The Semantic Nexus is underpinned by three frameworks that cover architecture, performance tracking, and security.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-3">SDA</div>
          <h3 class="text-xl font-bold mb-3">Standardised Data Architecture</h3>
          <p class="text-white/60 leading-relaxed text-sm">Best practices for building a data pipeline and data model that is robust, flexible, and low cost — refined over years of real client work.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-3">IPF</div>
          <h3 class="text-xl font-bold mb-3">Integrated Performance Framework</h3>
          <p class="text-white/60 leading-relaxed text-sm">A systematised way of presenting the data model that strikes the right balance between simplicity and depth for all stakeholders.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
          <div class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-3">MSP</div>
          <h3 class="text-xl font-bold mb-3">Modular Security Protocol</h3>
          <p class="text-white/60 leading-relaxed text-sm">A structured set of security checks designed for client-side and open-core architectures, where the security environment is inherently more complex.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section id="stack" class="py-24 px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Built on best-in-class tooling</h2>
        <p class="text-xl text-slate-500 max-w-2xl mx-auto">We work with the leading modern data stack tools, keeping clients fully sovereign over their own infrastructure.</p>
      </div>

      <!-- Pipeline stages -->
      <div class="flex flex-col md:flex-row items-stretch gap-0 md:min-h-[220px]">

        {[
          {
            stage: 'Extraction',
            color: 'bg-violet-50 border-violet-200',
            labelColor: 'text-violet-600',
            tools: [
              { src: '/logos/hevo.png', alt: 'Hevo Data' },
            ]
          },
          {
            stage: 'Warehouse',
            color: 'bg-blue-50 border-blue-200',
            labelColor: 'text-blue-600',
            tools: [
              { src: '/logos/bigquery.png', alt: 'BigQuery' },
              { src: '/logos/snowflake.png', alt: 'Snowflake' },
            ]
          },
          {
            stage: 'Transformation & Semantics',
            color: 'bg-emerald-50 border-emerald-200',
            labelColor: 'text-emerald-600',
            tools: [
              { src: '/logos/dbt.png', alt: 'dbt' },
              { src: '/logos/cube.png', alt: 'Cube' },
            ]
          },
          {
            stage: 'Visualisation',
            color: 'bg-orange-50 border-orange-200',
            labelColor: 'text-orange-600',
            tools: [
              { src: '/logos/looker-studio.png', alt: 'Looker Studio' },
              { src: '/logos/powerbi.png', alt: 'Power BI' },
            ]
          },
        ].map((group, i) => (
          <div class="flex md:flex-row items-stretch flex-1">
            <div class={`flex-1 h-full border ${group.color} rounded-2xl p-8 flex flex-col gap-6 justify-between`}>
              <span class={`text-xs font-bold uppercase tracking-widest ${group.labelColor}`}>{group.stage}</span>
              <div class="flex flex-row md:flex-col gap-4 items-center justify-center">
                {group.tools.map(tool => (
                  <img src={tool.src} alt={tool.alt} class="h-12 w-auto object-contain max-w-[140px]" />
                ))}
              </div>
            </div>
            {i < 3 && (
              <div class="hidden md:flex items-center px-2 text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            )}
          </div>
        ))}

      </div>

      <!-- GitHub version control bar -->
      <div class="mt-3 border border-slate-200 bg-slate-100 rounded-2xl px-8 py-4 flex items-center justify-between gap-4">
        <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Version Control</span>
        <img src="/logos/github.png" alt="GitHub" class="h-12 w-auto object-contain" />
        <span></span>
      </div>

      <p class="text-center text-sm text-slate-400 mt-6">All repositories are version-controlled and client-owned — no vendor lock-in, full sovereignty.</p>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="py-24 px-6 bg-slate-50">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-slate-900 mb-6">Pricing</h2>
      <div class="bg-white border border-slate-200 rounded-2xl p-12 shadow-sm">
        <div class="text-5xl font-extrabold text-brand-600 mb-2">Free</div>
        <p class="text-slate-500 text-lg mb-8">The Semantic Nexus and all its components are included at no charge for all our clients.</p>
        <p class="text-slate-700 text-base leading-relaxed max-w-xl mx-auto">
          We only charge our standard hourly rate for implementation. No licensing fees, no hidden costs — just the time it takes to build it right.
        </p>
        <div class="mt-10">
          <a href="https://calendly.com/philip-boontje" target="_blank" rel="noopener" class="bg-brand-600 text-white font-semibold px-10 py-4 rounded-xl hover:bg-brand-700 transition-colors text-lg inline-block">
            Start a conversation
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-brand-950 text-white pt-10 pb-6 px-6">
    <div class="max-w-6xl mx-auto">

      <!-- Top: logo + tagline -->
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 pb-6 border-b border-white/10">
        <div class="flex items-center gap-3">
          <img src="/maxq-logo.png" alt="Maxq Analytics" class="h-8 w-8 rounded-md object-cover" />
          <p class="text-white/40 text-xs italic">Fractional data engineering for dependable performance tracking.</p>
        </div>
        <a href="https://calendly.com/philip-boontje" target="_blank" rel="noopener" class="bg-brand-600 text-white text-xs font-semibold px-4 py-2 rounded-lg hover:bg-brand-500 transition-colors shrink-0">
          Book a call
        </a>
      </div>

      <!-- Link grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-8 border-b border-white/10">

        <!-- Services -->
        <div>
          <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-3">Services</h4>
          <ul class="space-y-1.5 text-xs text-white/50">
            <li><a href="https://www.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Data Engineering</a></li>
            <li><a href="https://www.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Uptime Monitoring</a></li>
          </ul>
        </div>

        <!-- Product Items -->
        <div>
          <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-3">Product Items</h4>
          <ul class="space-y-1.5 text-xs text-white/50">
            <li><a href="https://docs.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Data Entry Tests</a></li>
            <li><a href="https://docs.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Pipeline Freshness</a></li>
            <li><a href="https://docs.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Domain Reports</a></li>
            <li><a href="https://docs.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Data Model Explorer</a></li>
            <li><a href="https://docs.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">MCP Server</a></li>
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-3">Resources</h4>
          <ul class="space-y-1.5 text-xs text-white/50">
            <li><a href="https://docs.maxqanalytics.io/" target="_blank" rel="noopener" class="hover:text-white transition-colors">Documentation</a></li>
            <li><a href="https://www.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Case studies</a></li>
          </ul>
        </div>

        <!-- Partners -->
        <div>
          <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-3">Partners</h4>
          <ul class="space-y-1.5 text-xs text-white/50">
            <li><a href="https://www.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Integrations</a></li>
            <li><a href="https://www.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">Partner programme</a></li>
          </ul>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/30">
        <span>&copy; {new Date().getFullYear()} Maxq Analytics. All rights reserved.</span>
        <a href="https://www.maxqanalytics.io" target="_blank" rel="noopener" class="hover:text-white transition-colors">maxqanalytics.io</a>
      </div>

    </div>
  </footer>
</Layout>
